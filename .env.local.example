# Public site URL used for canonical/OG metadata. No trailing slash.
# Example production value: https://thesausageguy.shop
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public base path for the Panglao branch. The page lives at this path.
# Default keeps the brief's target: https://thesausageguy.shop/panglao
NEXT_PUBLIC_PANGLAO_PATH=/panglao
